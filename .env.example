# Environment Configuration for Audit Agent
# Copy this to .env and fill in your values

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AI Provider Configuration
# Supported values: openai, ollama
LLM_PROVIDER=openai
LLM_MODEL=
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Database (SQLite by default)
DATABASE_URL=sqlite:///./audit_agent.db

# Celery/Redis Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Task Mode Toggle
# Set to "true" to use mock tasks (no OpenAI API calls, for testing)
# Set to "false" to use real OpenAI tasks (production mode)
USE_MOCK_TASK=false

# JWT Secret (generate a random string for production)
SECRET_KEY=your-secret-key-for-jwt-tokens-change-in-production

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
